# ──────────────────────────────────────────────────────────────
# apps/api/.env.example
#
# How to use:
#   cp apps/api/.env.example apps/api/.env
#   Fill in your values, then run: npm run dev
#
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=3001

# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://supabase.com → Project → Settings → API
#
# SUPABASE_URL: your project URL (safe to expose)
SUPABASE_URL=https://your-project-id.supabase.co

# SUPABASE_SERVICE_KEY: service role key (server-side ONLY — never expose)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Fallback behaviour ────────────────────────────────────────
# If SUPABASE_URL / SUPABASE_SERVICE_KEY are empty or invalid,
# the app automatically falls back to bundled seed data (orders.json).
# Supabase is NOT required for local development.
